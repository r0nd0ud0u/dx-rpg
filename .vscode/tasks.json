{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "avdName",
      "type": "promptString",
      "description": "Android emulator AVD name (list with: emulator -list-avds)",
      "default": "Pixel_4"
    },
    {
      "id": "androidServerUrl",
      "type": "promptString",
      "description": "Server URL for the Android client (10.0.2.2 for the emulator, or http://<lan-ip>:8080 for a real device)",
      "default": "http://10.0.2.2:8080"
    }
  ],
  "tasks": [
    {
      "label": "Dev: Android Emulator",
      "type": "shell",
      "command": "./scripts/dev_emulator.sh",
      "args": ["${input:avdName}"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "panel": "dedicated", "group": "dx-dev" }
    },
    {
      "label": "Dev: Web Server (main)",
      "type": "shell",
      "command": "./scripts/dev_web.sh",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "panel": "dedicated", "group": "dx-dev" }
    },
    {
      "label": "Dev: Desktop Client",
      "type": "shell",
      "command": "./scripts/dev_desktop.sh",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "panel": "dedicated", "group": "dx-dev" }
    },
    {
      "label": "Dev: Android Client",
      "type": "shell",
      "command": "SERVER_URL=${input:androidServerUrl} ./scripts/dev_android.sh",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "panel": "dedicated", "group": "dx-dev" }
    },
    {
      "label": "Dev: Start All (Web, Desktop, Android, Emulator)",
      "dependsOn": [
        "Dev: Android Emulator",
        "Dev: Web Server (main)",
        "Dev: Desktop Client",
        "Dev: Android Client"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
