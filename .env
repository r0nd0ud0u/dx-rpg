IP=127.0.0.1
PORT=8080
DATABASE_URL="sqlite://db.sqlite"
# Native desktop/mobile client server URL. Takes priority over any value persisted
# via the in-app Server Settings dialog, so local dev always targets the local server.
#SERVER_URL=http://127.0.0.1:8080
SERVER_URL=https://aogin-world.com
# Uncomment if the server uses a self-signed or IP-only TLS certificate
#INSECURE_ACCEPT_INVALID_CERTS=true
# Set the log level for the application (e.g., "trace", "debug", "info", "warn", "error")
# Set to true to require a password on login/register (default: false)
USE_PASSWORD=false
# Maximum number of save slots per user (default: 3)
MAX_SAVES=3
# Enable/disable the admin CRUD panel (default: true)
ADMIN_ENABLED=true
LOG_LEVEL=info