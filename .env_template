IP=127.0.0.1
PORT=8080
DATABASE_URL="sqlite://db.sqlite"
# Native desktop/mobile client server URL. Takes priority over any value persisted
# via the in-app Server Settings dialog, so local dev always targets the local server.
#SERVER_URL=http://127.0.0.1:8080
# Example remote deployment (uncomment and adjust to point a native client at a real server):
#SERVER_URL=https://your-domain.example.com
# Uncomment if the server uses a self-signed or IP-only TLS certificate
#INSECURE_ACCEPT_INVALID_CERTS=true
# Set the log level for the application (e.g., "trace", "debug", "info", "warn", "error")
LOG_LEVEL=info
# Set to true to require a password on login/register (default: false)
USE_PASSWORD=false
# Maximum number of save slots per user (default: 3)
MAX_SAVES=3
# Enable/disable the admin CRUD panel (default: false)
ADMIN_ENABLED=false
# Set to true on the one authoritative server instance to reset every user's
# is_connected status on startup. Leave false on any secondary/staging instance
# sharing the same database, or it will wipe out live connections. (default: false)
IS_MAIN_SERVER=false
